<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Hướng Nghiệp Ngành AI</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --ink:#050505; --ink2:#0d0d0d; --ink3:#111; --ink4:#161616;
  --border:#242424; --border2:#2e2e2e;
  --text:#e8e6e1; --dim:#7a7872; --muted:#3a3835;
  --gold:#c8a45a; --gold2:rgba(200,164,90,.15);
  --cyan:#4dd9c0; --white:#f5f3ee;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html,body{width:100%;height:100%;overflow:hidden;background:var(--ink);font-family:'DM Sans',sans-serif;cursor:none}

/* CURSOR */
#cur{position:fixed;top:0;left:0;pointer-events:none;z-index:9999;width:10px;height:10px;background:var(--gold);border-radius:50%;transform:translate(-50%,-50%);transition:width .18s,height .18s;mix-blend-mode:screen}
#cur.big{width:44px;height:44px;opacity:.35}
body.zoom-on #cur{mix-blend-mode:normal;background:var(--gold);box-shadow:0 0 16px var(--gold)}
body.zoom-on #cur.big{width:60px;height:60px;opacity:.4}

/* PROGRESS */
#prog{position:fixed;top:0;left:0;height:2px;background:var(--gold);z-index:8000;transition:width .5s cubic-bezier(.4,0,.2,1)}

/* UI OVERLAYS */
#slide-idx{position:fixed;bottom:20px;right:28px;font-family:'DM Mono',monospace;font-size:11px;letter-spacing:.15em;color:#282828;z-index:2000}
#hint{position:fixed;bottom:20px;left:50%;transform:translateX(-50%);font-family:'DM Mono',monospace;font-size:10px;letter-spacing:.25em;color:var(--muted);text-transform:uppercase;z-index:2000;pointer-events:none}
#site-link{position:fixed;bottom:20px;left:24px;font-family:'DM Mono',monospace;font-size:10px;letter-spacing:.12em;color:#2a2a2a;z-index:2000;text-decoration:none;transition:color .2s}
#site-link:hover{color:var(--gold)}

/* ZOOM TOGGLE */
#zt{position:fixed;top:20px;right:24px;z-index:9000;display:flex;align-items:center;gap:9px;background:var(--ink2);border:1px solid var(--border2);padding:9px 16px;cursor:pointer;font-family:'DM Mono',monospace;font-size:11px;letter-spacing:.18em;color:var(--dim);text-transform:uppercase;transition:border-color .25s,color .25s,background .25s;user-select:none}
#zt:hover{border-color:var(--gold);color:var(--white)}
#zt.on{border-color:var(--gold);background:rgba(200,164,90,.1);color:var(--gold)}
.zt-dot{width:7px;height:7px;border-radius:50%;background:var(--muted);transition:background .25s,box-shadow .25s;flex-shrink:0}
#zt.on .zt-dot{background:var(--gold);box-shadow:0 0 8px var(--gold)}
.zt-k{font-size:9px;opacity:.5;border:1px solid currentColor;padding:1px 5px;border-radius:2px;margin-left:3px}

/* ============================
   ZOOM SYSTEM
============================ */
.z{transition:transform .3s cubic-bezier(.34,1.56,.64,1),box-shadow .3s,border-color .28s,background .28s}
body:not(.zoom-on) .z:hover{transform:scale(1.05);z-index:50;position:relative;box-shadow:0 20px 60px rgba(0,0,0,.8),0 0 0 1px var(--gold)}

body.zoom-on .z:hover{
  transform:scale(1.6)!important;
  z-index:500;position:relative;
  box-shadow:0 40px 120px rgba(0,0,0,.97),0 0 0 2px var(--gold);
  filter:brightness(1.15)
}
/* zoom text elements too */
.zt{transition:transform .3s cubic-bezier(.34,1.56,.64,1),text-shadow .3s,color .3s}
body.zoom-on .zt:hover{
  transform:scale(1.4)!important;
  z-index:500;position:relative;display:inline-block;
  text-shadow:0 0 40px rgba(200,164,90,.4);
  color:var(--white)!important;
}

/* ============================
   DECK
============================ */
#deck{position:fixed;inset:0}
.slide{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity .5s cubic-bezier(.4,0,.2,1);overflow:hidden}
.slide.active{opacity:1;pointer-events:all}

/* GRID BG */
.grid-bg{position:absolute;inset:0;background-image:linear-gradient(rgba(200,164,90,.022) 1px,transparent 1px),linear-gradient(90deg,rgba(200,164,90,.022) 1px,transparent 1px);background-size:80px 80px;animation:gridDrift 28s linear infinite}
@keyframes gridDrift{to{background-position:80px 80px}}

/* REVEAL */
.rv{opacity:0;transform:translateY(26px);transition:opacity .6s,transform .6s cubic-bezier(.4,0,.2,1)}
.slide.active .rv{opacity:1;transform:translateY(0)}
.slide.active .rv:nth-child(1){transition-delay:.07s}
.slide.active .rv:nth-child(2){transition-delay:.17s}
.slide.active .rv:nth-child(3){transition-delay:.27s}
.slide.active .rv:nth-child(4){transition-delay:.37s}
.slide.active .rv:nth-child(5){transition-delay:.47s}
.slide.active .rv:nth-child(6){transition-delay:.57s}
.slide.active .rv:nth-child(7){transition-delay:.67s}
.slide.active .rv:nth-child(8){transition-delay:.77s}

/* SHARED */
.s-label{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:.3em;text-transform:uppercase;color:var(--gold);margin-bottom:16px}
.mega{font-family:'Playfair Display',serif;font-size:clamp(40px,6vw,84px);font-weight:900;color:var(--white);line-height:.95}
.mega em{font-style:italic;color:var(--gold)}
.full-pad{width:100%;max-width:1400px;padding:52px 64px}

/* ============================
   S0 — INTRO
============================ */
#s0{background:var(--ink);flex-direction:column}
.s0-bg{
  position:absolute;inset:0;
  background:
    radial-gradient(ellipse 90% 70% at 15% 50%,rgba(200,164,90,.09) 0%,transparent 55%),
    radial-gradient(ellipse 60% 80% at 85% 25%,rgba(77,217,192,.06) 0%,transparent 50%),
    radial-gradient(ellipse 40% 40% at 50% 80%,rgba(200,164,90,.04) 0%,transparent 50%);
  animation:bgPulse 8s ease-in-out infinite alternate
}
@keyframes bgPulse{to{opacity:.6}}

/* Floating AI logos */
.ai-float{position:absolute;pointer-events:none;user-select:none;font-size:clamp(24px,4vw,48px);opacity:.12;filter:grayscale(1)}
.ai-float img{width:clamp(32px,4vw,56px);height:clamp(32px,4vw,56px);object-fit:contain;opacity:.15;filter:grayscale(1) brightness(2)}

.af1{top:8%;left:5%;animation:floatA 7s ease-in-out infinite}
.af2{top:15%;right:8%;animation:floatB 9s ease-in-out infinite .5s}
.af3{bottom:20%;left:7%;animation:floatA 11s ease-in-out infinite 1s}
.af4{bottom:12%;right:6%;animation:floatB 8s ease-in-out infinite 1.5s}
.af5{top:45%;left:2%;animation:floatA 10s ease-in-out infinite 2s}
.af6{top:40%;right:3%;animation:floatB 12s ease-in-out infinite .8s}
.af7{top:70%;left:30%;animation:floatA 9s ease-in-out infinite 3s;font-size:20px}
.af8{top:5%;left:40%;animation:floatB 13s ease-in-out infinite 1.2s;font-size:18px}
@keyframes floatA{0%,100%{transform:translateY(0) rotate(-3deg)}50%{transform:translateY(-18px) rotate(3deg)}}
@keyframes floatB{0%,100%{transform:translateY(0) rotate(2deg)}50%{transform:translateY(-14px) rotate(-4deg)}}

.s0-inner{position:relative;z-index:2;text-align:center;max-width:1040px;padding:40px}
.s0-eye{font-family:'DM Mono',monospace;font-size:clamp(11px,1vw,13px);letter-spacing:.4em;color:var(--gold);text-transform:uppercase;margin-bottom:30px;opacity:0;animation:rU .8s .25s forwards}
.s0-h1{font-family:'Playfair Display',serif;font-size:clamp(62px,12vw,148px);font-weight:900;line-height:.88;color:var(--white);letter-spacing:-.03em;opacity:0;animation:rU .9s .55s forwards}
.s0-h1 em{display:block;font-style:italic;font-weight:400;color:transparent;-webkit-text-stroke:1.5px var(--gold)}
.s0-sub{font-size:clamp(16px,2vw,24px);color:var(--dim);font-weight:300;margin-top:30px;line-height:1.65;opacity:0;animation:rU .9s .85s forwards;max-width:640px;margin-inline:auto}
.s0-tags{display:flex;gap:14px;justify-content:center;flex-wrap:wrap;margin-top:42px;opacity:0;animation:rU .9s 1.1s forwards}

/* ANIMATED TAGS — pulse independently */
.tag{
  font-family:'DM Mono',monospace;font-size:11px;letter-spacing:.2em;color:var(--dim);
  text-transform:uppercase;border:1px solid var(--border2);padding:8px 20px;
}
.tag:nth-child(1){animation:tagPulse1 3.2s ease-in-out infinite 1.4s}
.tag:nth-child(2){animation:tagPulse2 4.1s ease-in-out infinite 1.6s}
.tag:nth-child(3){animation:tagPulse1 3.7s ease-in-out infinite 1.8s}
.tag:nth-child(4){animation:tagPulse2 5s ease-in-out infinite 2s}
@keyframes tagPulse1{
  0%,100%{transform:scale(1);border-color:var(--border2);color:var(--dim)}
  50%{transform:scale(1.08);border-color:rgba(200,164,90,.6);color:var(--text)}
}
@keyframes tagPulse2{
  0%,100%{transform:scale(1) translateY(0);border-color:var(--border2);color:var(--dim)}
  40%{transform:scale(1.06) translateY(-3px);border-color:rgba(200,164,90,.5);color:var(--text)}
}

.s0-rule{width:1px;height:52px;background:linear-gradient(to bottom,transparent,var(--gold),transparent);margin:34px auto 0;opacity:0;animation:rU .7s 1.3s forwards}
@keyframes rU{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}

/* ============================
   S1 — AI LÀ GÌ
============================ */
#s1{background:var(--ink)}
/* Subtle neural net bg */
.neural-bg{position:absolute;inset:0;opacity:.04;background-image:radial-gradient(circle,rgba(200,164,90,.8) 1px,transparent 1px);background-size:48px 48px}

.four-col{display:grid;grid-template-columns:repeat(4,1fr);gap:3px;margin-top:36px}
.ai-card{background:var(--ink3);padding:36px 28px;border-top:2px solid var(--border);cursor:default;position:relative;overflow:hidden}
.ai-card::after{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(200,164,90,.03),transparent);opacity:0;transition:opacity .4s}
.ai-card:hover::after{opacity:1}
.ai-card:hover{border-top-color:var(--gold);background:#0e0e0e}
.c-icon{font-size:32px;margin-bottom:18px;display:block;transition:transform .3s}
.ai-card:hover .c-icon{transform:scale(1.2)}
.c-title{font-family:'Playfair Display',serif;font-size:clamp(18px,2vw,26px);font-weight:700;color:var(--white);margin-bottom:12px}
.c-body{font-size:clamp(13px,1.2vw,16px);color:var(--dim);line-height:1.7;font-weight:300}
.c-tag{display:inline-block;margin-top:14px;font-family:'DM Mono',monospace;font-size:10px;letter-spacing:.15em;color:var(--gold);border:1px solid rgba(200,164,90,.3);padding:4px 12px}

/* AI logo row */
.ai-logos-row{display:flex;gap:20px;align-items:center;margin-top:32px;flex-wrap:wrap}
.ai-logo-chip{
  display:flex;align-items:center;gap:10px;
  padding:10px 18px;border:1px solid var(--border2);background:var(--ink3);
  font-family:'DM Mono',monospace;font-size:11px;letter-spacing:.1em;color:var(--dim);
  transition:border-color .3s,color .3s,transform .3s;
}
.ai-logo-chip:hover{border-color:var(--gold);color:var(--white);transform:translateY(-3px)}
.ai-logo-chip img{width:20px;height:20px;object-fit:contain;border-radius:4px}
.ai-logo-emoji{font-size:18px}

/* ============================
   S2 — NGHỀ NGHIỆP
============================ */
#s2{background:var(--ink2)}
.job-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:32px}
.job-card{background:var(--ink);border:1px solid var(--border);padding:30px 26px;position:relative;overflow:hidden;cursor:default}
.job-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--gold);transform:scaleX(0);transform-origin:left;transition:transform .4s}
.job-card:hover::before{transform:scaleX(1)}
.jn{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:.2em;color:var(--gold);margin-bottom:12px}
.jtitle{font-family:'Playfair Display',serif;font-size:clamp(18px,2vw,26px);font-weight:700;color:var(--white);margin-bottom:10px;line-height:1.2}
.jdesc{font-size:clamp(13px,1.2vw,15px);color:var(--dim);line-height:1.65;font-weight:300;margin-bottom:14px}
.jsal{font-family:'DM Mono',monospace;font-size:clamp(13px,1.4vw,18px);color:var(--cyan)}
.jlvl{display:flex;gap:5px;margin-top:12px;flex-wrap:wrap}
.lvl{font-size:10px;letter-spacing:.08em;color:var(--dim);border:1px solid var(--border2);padding:3px 9px;font-family:'DM Mono',monospace}

/* ============================
   S3 — KỸ NĂNG
============================ */
#s3{background:var(--ink)}
.two-even{display:grid;grid-template-columns:1fr 1fr;gap:72px;width:100%;max-width:1400px;padding:52px 64px;align-items:center}
.skill-list{display:flex;flex-direction:column;gap:13px}
.sk{display:flex;align-items:flex-start;gap:18px;padding:22px 26px;border:1px solid var(--border);background:var(--ink2);cursor:default}
.sk:hover{border-color:var(--gold);background:var(--ink3)}
.sk-dot{width:9px;height:9px;background:var(--gold);border-radius:50%;margin-top:10px;flex-shrink:0;transition:transform .3s}
.sk:hover .sk-dot{transform:scale(1.8)}
.sk-main{font-size:clamp(15px,1.6vw,21px);color:var(--text);line-height:1.4;font-weight:500}
.sk-sub{font-size:clamp(12px,1.1vw,14px);color:var(--dim);margin-top:5px}
.quote-box{margin-top:26px;border-left:3px solid var(--gold);padding:22px 28px;background:var(--ink3)}
.q-text{font-family:'Playfair Display',serif;font-style:italic;font-size:clamp(16px,1.8vw,23px);color:var(--white);line-height:1.55}
.q-src{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:.2em;color:var(--gold);margin-top:10px}

/* ============================
   S4 — THÁCH THỨC
============================ */
#s4{background:var(--ink2)}
.chal-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:32px}
.chal{padding:34px 28px;border:1px solid var(--border);background:var(--ink);position:relative;overflow:hidden;cursor:default}
.chal:hover{border-color:var(--gold)}
.chal-bg-num{position:absolute;top:-12px;right:14px;font-family:'Playfair Display',serif;font-size:88px;font-weight:900;color:var(--border);line-height:1;pointer-events:none;transition:color .3s}
.chal:hover .chal-bg-num{color:rgba(200,164,90,.1)}
.chal-ico{font-size:26px;margin-bottom:14px}
.chal-ttl{font-family:'Playfair Display',serif;font-size:clamp(18px,2vw,25px);font-weight:700;color:var(--white);margin-bottom:10px}
.chal-txt{font-size:clamp(13px,1.2vw,15px);color:var(--dim);line-height:1.7}

/* ============================
   S5 — LỘ TRÌNH
============================ */
#s5{background:var(--ink)}
.road-wrap{width:100%;max-width:1400px;padding:52px 60px}
.road-row{display:grid;grid-template-columns:repeat(4,1fr);gap:0;position:relative;margin-top:40px}
.road-row::before{content:'';position:absolute;top:26px;left:26px;right:26px;height:1px;background:var(--border2)}
.rs{padding:0 16px 0 0;position:relative;z-index:1;cursor:default}
.rs-dot{width:14px;height:14px;background:var(--border2);border:2px solid var(--border2);border-radius:50%;margin-bottom:20px;transition:background .3s,border-color .3s,transform .3s}
.rs:hover .rs-dot{background:var(--gold);border-color:var(--gold);transform:scale(1.5)}
.rs-phase{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:.2em;color:var(--gold);text-transform:uppercase;margin-bottom:8px}
.rs-title{font-family:'Playfair Display',serif;font-size:clamp(17px,1.9vw,24px);font-weight:700;color:var(--white);margin-bottom:12px}
.rs-list{list-style:none;display:flex;flex-direction:column;gap:7px}
.rs-list li{font-size:clamp(13px,1.2vw,15px);color:var(--dim);line-height:1.5;padding-left:14px;position:relative}
.rs-list li::before{content:'—';position:absolute;left:0;color:var(--border2)}
.school-row{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-top:30px}
.sc{background:var(--ink2);border:1px solid var(--border);padding:18px 22px;cursor:default}
.sc:hover{border-color:var(--gold)}
.sc-name{font-size:clamp(14px,1.4vw,18px);color:var(--white);font-weight:500;margin-bottom:5px}
.sc-info{font-family:'DM Mono',monospace;font-size:10px;color:var(--dim);letter-spacing:.1em}

/* ============================
   S6 — LƯƠNG
============================ */
#s6{background:var(--ink2)}
.sal-layout{display:grid;grid-template-columns:1fr 1fr;gap:60px;width:100%;max-width:1400px;padding:52px 64px;align-items:start}
.sal-list{display:flex;flex-direction:column;gap:12px;margin-top:22px}
.sal-row{display:flex;align-items:center;gap:20px;padding:22px 24px;background:var(--ink);border:1px solid var(--border);cursor:default}
.sal-row:hover{border-color:var(--gold)}
.sal-title{flex:1;font-size:clamp(15px,1.6vw,21px);color:var(--white);font-weight:500}
.sal-num{font-family:'DM Mono',monospace;font-size:clamp(14px,1.5vw,19px);color:var(--cyan);white-space:nowrap}
.stat-col{display:flex;flex-direction:column;gap:13px;margin-top:22px}
.stat-b{background:var(--ink);border:1px solid var(--border);padding:28px 32px;cursor:default}
.stat-b:hover{border-color:var(--gold)}
.stat-n{font-family:'Playfair Display',serif;font-size:clamp(36px,5.5vw,68px);font-weight:900;color:var(--white);line-height:1}
.stat-n span{color:var(--gold)}
.stat-lbl{font-size:clamp(12px,1.2vw,15px);color:var(--dim);margin-top:6px;line-height:1.5}

/* ============================
   S7 — THÀNH VIÊN
============================ */
#s7{background:var(--ink)}
.team-bg{
  position:absolute;inset:0;
  background:
    radial-gradient(ellipse 60% 50% at 20% 50%,rgba(200,164,90,.06) 0%,transparent 55%),
    radial-gradient(ellipse 50% 60% at 80% 40%,rgba(77,217,192,.04) 0%,transparent 50%)
}
.team-wrap{width:100%;max-width:1400px;padding:48px 60px;position:relative;z-index:2}
.team-header{display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:40px}
.team-title{font-family:'Playfair Display',serif;font-size:clamp(36px,5.5vw,72px);font-weight:900;color:var(--white);line-height:1}
.team-title em{font-style:italic;color:var(--gold)}
.team-site{font-family:'DM Mono',monospace;font-size:12px;letter-spacing:.15em;color:var(--dim);text-align:right}
.team-site a{color:var(--gold);text-decoration:none}
.team-site a:hover{text-decoration:underline}
.members-grid{display:grid;grid-template-columns:repeat(6,1fr);gap:14px}
.member{
  padding:24px 18px;border:1px solid var(--border);background:var(--ink2);
  text-align:center;position:relative;overflow:hidden;
  transition:transform .35s cubic-bezier(.34,1.56,.64,1),border-color .3s,box-shadow .3s
}
.member:hover{border-color:var(--gold);transform:translateY(-6px) scale(1.04);z-index:10;box-shadow:0 20px 60px rgba(0,0,0,.8),0 0 0 1px var(--gold)}
.member.lead{border-color:rgba(200,164,90,.3);background:rgba(200,164,90,.05)}
.member.lead::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--gold)}
.m-avatar{
  width:56px;height:56px;border-radius:50%;border:1px solid var(--border2);
  display:flex;align-items:center;justify-content:center;
  font-size:22px;margin:0 auto 14px;background:var(--ink3);
  transition:border-color .3s,transform .3s
}
.member:hover .m-avatar{border-color:var(--gold);transform:scale(1.1)}
.member.lead .m-avatar{border-color:rgba(200,164,90,.5)}
.m-name{font-family:'Playfair Display',serif;font-size:clamp(12px,1.1vw,15px);font-weight:700;color:var(--white);margin-bottom:8px;line-height:1.3}
.m-role{font-family:'DM Mono',monospace;font-size:9px;letter-spacing:.12em;color:var(--dim);text-transform:uppercase;line-height:1.5}
.m-tag{display:inline-block;margin-top:10px;font-family:'DM Mono',monospace;font-size:8px;letter-spacing:.1em;padding:2px 8px;border:1px solid rgba(200,164,90,.4);color:var(--gold)}
.m-inactive .m-name{color:var(--muted)}
.m-inactive .m-avatar{opacity:.4}
.m-inactive .m-role{color:#2a2827}
.m-inactive::after{content:'—';position:absolute;top:12px;right:12px;font-family:'DM Mono',monospace;font-size:9px;color:var(--muted)}

/* ============================
   S8 — OUTRO
============================ */
#s8{background:var(--ink);flex-direction:column}
.s8-bg{position:absolute;inset:0;background:radial-gradient(ellipse 80% 60% at 50% 50%,rgba(200,164,90,.07) 0%,transparent 60%)}
.s8-inner{position:relative;z-index:2;text-align:center;max-width:860px;padding:40px}
.s8-tag{font-family:'DM Mono',monospace;font-size:11px;letter-spacing:.35em;color:var(--gold);text-transform:uppercase;margin-bottom:26px;opacity:0}
.slide.active .s8-tag{animation:rU .8s .2s forwards}
