  cur.style.top  = e.clientY + 'px';
});
document.addEventListener('mouseover', e => {
  cur.classList.toggle('big', !!(e.target.closest('.z,.zt,#zt,#site-link,.member,.ai-logo-chip')));
});

// ── ZOOM ──
let zoomOn = false;
const ztBtn = document.getElementById('zt');
function toggleZoom() {
  zoomOn = !zoomOn;
  document.body.classList.toggle('zoom-on', zoomOn);
  ztBtn.classList.toggle('on', zoomOn);
}

// ── SLIDES ──
const slides = document.querySelectorAll('.slide');
const prog   = document.getElementById('prog');
const idxEl  = document.getElementById('slide-idx');
let cur_s = 0;
function goTo(n) {
  if (n < 0 || n >= slides.length) return;
  slides[cur_s].classList.remove('active');
  cur_s = n;
  slides[cur_s].classList.add('active');
  prog.style.width = ((cur_s + 1) / slides.length * 100) + '%';
  idxEl.textContent = String(cur_s+1).padStart(2,'0') + ' / ' + String(slides.length).padStart(2,'0');
}

// ── KEYBOARD ──
document.addEventListener('keydown', e => {
  if (e.key==='z'||e.key==='Z') { toggleZoom(); return; }
  if (e.key==='ArrowRight'||e.key===' ') { e.preventDefault(); goTo(cur_s+1); }
  if (e.key==='ArrowLeft') goTo(cur_s-1);
});

// ── TOUCH ──
let tx = 0;
document.addEventListener('touchstart', e => tx = e.touches[0].clientX);
document.addEventListener('touchend', e => {
  const dx = e.changedTouches[0].clientX - tx;
  if (Math.abs(dx) > 50) dx < 0 ? goTo(cur_s+1) : goTo(cur_s-1);
});

goTo(0);
</script>
</body>
</html>
